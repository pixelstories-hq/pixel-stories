---
import Footer from "./Footer/Footer.astro";
import { Icon } from "@astrojs/starlight/components";
---

<main
  class="not-content relative mx-auto flex max-w-7xl flex-col gap-24 px-0 sm:px-6 lg:px-8"
>
  <!-- WHY JOIN -->
  <section class="grid gap-8 p-4 lg:grid-cols-5">
    <div class="lg:col-span-2 flex flex-col gap-6">
      <h2 class="text-3xl font-bold">
        Why join the <span class="text-nowrap">Pixel Stories</span> community?
      </h2>
      <p class="text-base leading-6 text-base-content/80">
        A welcoming hub for story-driven game creators to connect, brainstorm,
        build teams, share feedback, playtest, and showcase their work.
      </p>
      <a href="https://discord.gg/your-invite" class="btn btn-outline w-max"
        >Join our Discord</a
      >
    </div>

    <ul class="p-0 lg:col-span-3 grid gap-3 sm:grid-cols-2">
      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="star" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Community for Story Creators</h3>
        <p class="text-base-content/80">
          Meet others making top-down, narrative-focused 2D games.
        </p>
      </li>

      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="pencil" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Brainstorm Ideas Together</h3>
        <p class="text-base-content/80">
          Share ideas, refine concepts, and spark new directions.
        </p>
      </li>

      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="add-document" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Build a Team</h3>
        <p class="text-base-content/80">
          Post your project, find collaborators, and start strong.
        </p>
      </li>

      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="document" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Share & Get Feedback</h3>
        <p class="text-base-content/80">
          Get constructive feedback on story, art, music, and design.
        </p>
      </li>

      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="laptop" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Playtest Together</h3>
        <p class="text-base-content/80">
          Exchange demo and improve game pacing, mechanics, and polish.
        </p>
      </li>

      <li
        class="list-none space-y-2 rounded-2xl border border-base-300 bg-base-100 p-5 text-sm shadow-sm"
      >
        <Icon name="rocket" color="var(--color-accent)" size="2rem" />
        <h3 class="font-semibold">Celebrate Game Releases!</h3>
        <p class="text-base-content/80">
          Showcase finished games and celebrate that big milestone.
        </p>
      </li>
    </ul>
  </section>

  <!-- COMMUNITY -->
  <section
    class="flex flex-col items-center justify-center text-center p-4 py-8"
  >
    <div class="max-w-xl flex flex-col gap-4 items-center">
      <h2 class="text-4xl font-bold">
        A community that loves making 2D story-driven games
      </h2>
      <p class="text-base text-base-content/80">
        Share your work, get feedback, playtest, and connect with creators who
        love story-driven games!
      </p>
      <a href="https://discord.gg/your-invite" class="btn btn-primary w-max"
        >Join our Discord</a
      >
    </div>
  </section>

  <!-- FINAL CTA -->
  <section
    class="mb-20 overflow-hidden rounded-3xl border border-base-300 bg-gradient-to-r from-primary/12 to-accent/14 p-8 py-14 text-base-content shadow-sm"
  >
    <div
      class="mx-auto grid max-w-5xl items-center gap-8 text-base-content lg:grid-cols-3"
    >
      <div class="lg:col-span-2 space-y-4">
        <h2 class="text-3xl font-extrabold">
          Help shape the Pixel Stories community.
        </h2>
        <p class="mt-2 text-lg leading-6">
          Have ideas to make it better? Drop them in <span class="font-semibold"
            >#suggestions</span
          > channel. We want to make this a great community!
        </p>
      </div>
      <div class="flex items-center gap-3 lg:justify-end">
        <a href="https://discord.gg/your-invite" class="btn btn-primary"
          >Join our Discord</a
        >
      </div>
    </div>
  </section>

  <Footer />
</main>
