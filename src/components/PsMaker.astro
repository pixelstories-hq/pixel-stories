---
import Footer from "./Footer/Footer.astro";
import img from "../assets/images/dead-friend-horror.png";
import Image from "astro/components/Image.astro";
import logo from "../../public/logo-icon.png";
import DownloadModal from "./DownloadModal.astro";
import Video from "./Video.astro";
import mapEditorVideo from "../assets/images/home-page/map-editor.mp4";
import eventsVideo from "../assets/images/home-page/editing-event.mp4";
import playTestVideo from "../assets/images/home-page/play-test.mp4";
import actionsScreenshot from "../assets/images/home-page/actions.png";
import assetsScreenshot from "../assets/images/home-page/assets.png";
---

<main
  class="not-content relative mx-auto flex max-w-7xl flex-col gap-24 px-0 sm:px-6 lg:px-8"
>
  <!-- HERO -->
  <section class="mt-10 flex flex-col items-start gap-4 text-left w-full">
    <div class="flex gap-2 items-center ml-1">
      <Image src={logo} alt="PS Maker logo" class="w-7 h-7 not-content" />
      <p class="font-semibold text-3xl">PS Maker</p>
    </div>

    <h1
      class="max-w-2xl text-pretty text-5xl font-bold tracking-tight sm:text-4xl lg:text-6xl leading-tight"
    >
      The 2D Game Maker Built for Telling Stories
    </h1>

    <p class="max-w-xl w-full text-pretty text-base-content/80 text-lg">
      <strong>PS Maker</strong> lets you build immersive story-driven games without
      the need to code, letting you focus on the narrative, art direction, world building,
      and character design.
    </p>

    <div class="flex gap-3">
      <DownloadModal />
      <a href="/overview" class="daisy-btn"> Help documentation </a>
    </div>
  </section>

  <iframe
    src="https://itch.io/embed/4434961?linkback=true"
    width="552"
    height="167"
  >
  </iframe>

  <section class="flex flex-col items-center justify-center gap-3">
    <p class="text-3xl font-semibold">2D Top-down Map Editor</p>
    <Video
      src={mapEditorVideo}
      class="w-full rounded-xl border border-base-300 bg-base-100"
    />
  </section>

  <section class="flex flex-col items-center justify-center gap-3">
    <p class="text-3xl font-semibold">No-code Event System</p>

    <Video
      src={eventsVideo}
      class="w-full rounded-xl border border-base-300 bg-base-100"
    />
  </section>

  <section class="flex flex-col items-center justify-center gap-3">
    <p class="text-3xl font-semibold">Powered by Actions</p>

    <Image
      class="w-full rounded-xl border border-base-300 bg-base-100"
      src={actionsScreenshot}
      alt="Actions screenshot"
    />
  </section>

  <section class="flex flex-col items-center justify-center gap-3">
    <p class="text-3xl font-semibold">Play Test Your Game</p>

    <Video
      src={playTestVideo}
      class="w-full rounded-xl border border-base-300 bg-base-100"
    />
  </section>

  <section class="flex flex-col items-center justify-center gap-3">
    <p class="text-3xl font-semibold">Free Starter Assets</p>

    <Image
      class="w-full rounded-xl border border-base-300 bg-base-100"
      src={assetsScreenshot}
      alt="Assets screenshot"
    />
  </section>

  <!-- FEATURED GAME / SPLASH SECTION -->
  <section
    class="grid gap-8 mx-auto justify-items-center md:grid-cols-2 max-md:max-w-lg"
  >
    <a
      href="https://app.pixelstories.io/embed/ucUR89FNTR"
      target="_blank"
      rel="noopener noreferrer"
    >
      <Image
        src={img}
        alt="Gameplay screenshot"
        class="not-content aspect-[5/4] w-full max-md:aspect-[4/3] h-auto rounded-xl object-cover"
      />
    </a>

    <div class="max-w-xl py-6 space-y-6">
      <div class="space-y-2">
        <p class="text-lg font-medium">Made with PS Maker</p>

        <h2 class="text-pretty text-3xl font-bold tracking-tight sm:text-5xl">
          Dead Friend Horror
        </h2>
      </div>

      <p class="text-base leading-7 text-base-content/80">
        A fun hangout with your best friend suddenly turns sideways when a
        killer in the night "takes" your friend.
      </p>

      <div>
        <a
          href="https://tdgao.itch.io/dead-friend-horror"
          target="_blank"
          rel="noopener noreferrer"
          class="daisy-btn">Play now</a
        >
      </div>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section
    class="flex flex-col items-center justify-center text-center p-4 py-8"
  >
    <div class="max-w-xl flex flex-col gap-4 items-center">
      <h2 class="text-4xl font-bold text-pretty">
        Join our official Discord community
      </h2>
      <p class="text-base text-base-content/80 text-balance">
        Share your work, get feedback, playtest, and connect with creators who
        love story-driven games!
      </p>
      <a href="https://discord.gg/your-invite" class="daisy-btn"
        >Join our Discord</a
      >
    </div>
  </section>

  <!-- FINAL CTA -->
  <section
    class="mb-20 overflow-hidden rounded-xl border border-base-300 bg-base-300 p-8 text-base-content shadow-sm flex flex-col gap-6"
  >
    <div
      class="grid max-w-5xl pt-1 items-center gap-8 text-base-content lg:grid-cols-3"
    >
      <div class="lg:col-span-2 space-y-4">
        <h2 class="text-3xl font-bold">Ready? Make your game with PS Maker</h2>
        <p class="mt-2 text-lg leading-6">
          Download our free demo to start using PS Maker today!
        </p>
      </div>
      <div class="flex items-center gap-3 lg:justify-end">
        <DownloadModal btnSize="daisy-btn-lg" class="px-6" />
      </div>
    </div>

    <div class="w-full h-px bg-base-content/15"></div>

    <iframe
      src="https://itch.io/embed/4434961?linkback=true"
      width="552"
      height="167"
    >
    </iframe>
  </section>
</main>

<Footer />
