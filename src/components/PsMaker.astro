---
import { Icon } from "@astrojs/starlight/components";
import Footer from "./Footer/Footer.astro";
import Video from "./Video.astro";
import mapEditorVideo from "../assets/images/home-page/map-editor.mp4";
import eventsVideo from "../assets/images/home-page/editing-event.mp4";
import playTestVideo from "../assets/images/home-page/play-test.mp4";

const PLAY_DEMO_URL = "https://pixelstories.io/play/ae9fd4f0";
const STEAM_WIDGET_URL = "https://store.steampowered.com/widget/4823590/";
const STEAM_STORE_URL = "https://store.steampowered.com/app/4823590/PS_Maker/";

const featureSections = [
  {
    title: "Build Your World",
    media: {
      type: "video",
      src: mapEditorVideo,
      alt: "PS Maker map editor showing a top-down pixel art world",
    },
    intro: "Use the 2D top-down map editor to build your world.",
    bullets: [
      "Map objects with depth sorting and collisions",
      "Tilesets and autotiles with map layers",
      "Undo/Redo support",
    ],
  },
  {
    title: "Bring Your Story to Life",
    media: {
      type: "video",
      src: eventsVideo,
      alt: "PS Maker no-code event system editing a game interaction",
    },
    intro: "Create story moments, cutscenes, and game logic without code.",
    bullets: [
      "No-code Event System",
      "Control NPCs, trigger cutscenes, and build game mechanics",
      "Player interaction and touch trigger systems",
      "Built-in dialogue editor with names, portraits, and voice sounds",
      "Conditional branching with player choices and game variables",
      "Multiple endings",
    ],
  },
  {
    title: "Instantly Share with Friends",
    media: {
      type: "video",
      src: playTestVideo,
      alt: "PS Maker playtest view running a top-down story game",
    },
    intro: "Playtest quickly, polish your project, and keep expanding it.",
    bullets: [
      "Import custom art, music, and sounds",
      "Make animations, NPCs, tilesets, autotiles, map objects, and more",
      "Free starter assets",
      "Plugin system to extend your game with code",
      "Interactive tutorial project",
      "Dark mode",
      "Auto-updates forever with new features and continuous bug fixes",
    ],
  },
] as const;
---

<main
  class="not-content relative mx-auto flex max-w-10xl flex-col gap-32 px-0 sm:px-6 lg:px-8"
>
  <!-- HERO -->
  <section
    class="flex flex-col items-center gap-4 text-center not-content pt-10 pb-2"
  >
    <div class="flex items-center justify-between w-full max-w-5xl">
      <p
        class="max-w-4xl text-pretty text-left text-base-content font-semibold text-4xl leading-8 flex items-center gap-2"
      >
        <span class="inline-flex gap-2 items-center">
          <img src="/logo-icon.png" alt="" class="size-12 border-0" />
          <span>PS Maker:</span>
        </span>
        <span> Story Game Engine </span>
      </p>

      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/overview"
          class="daisy-btn daisy-btn-outline border border-base-300"
        >
          Read the manual
        </a>
        <a
          href={PLAY_DEMO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="daisy-btn"
        >
          Open web demo
          <Icon name="right-arrow" size="1rem" />
        </a>
      </div>
    </div>

    <div class="relative w-full">
      <a
        href={PLAY_DEMO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="daisy-btn daisy-btn-sm absolute left-1/2 top-4 z-10 -translate-x-1/2 border border-base-300 bg-base-100/95 shadow-sm backdrop-blur rounded-full"
      >
        Open tutorial project
        <Icon name="right-arrow" size="0.875rem" />
      </a>

      <iframe
        src={PLAY_DEMO_URL}
        title="PS Maker tutorial game"
        class="w-full aspect-video rounded-lg border border-base-300 bg-base-200"
        allow="fullscreen; gamepad"
        loading="lazy"
      >
      </iframe>
    </div>
  </section>

  <section class="-mt-8 flex flex-col items-center gap-4 text-center">
    <p
      class="mx-auto w-full max-w-4xl text-pretty text-2xl font-medium leading-8 text-base-content"
    >
      PS Maker lets you make 2D top-down story focused games without code, so
      you can focus on the narrative, characters, music and world building!
    </p>

    <a href={STEAM_STORE_URL} class="daisy-btn"> Buy now on Steam </a>
  </section>

  {
    featureSections.map((section) => (
      <section class="flex flex-col gap-4">
        <h2 class="text-pretty text-3xl font-bold tracking-tight">
          {section.title}
        </h2>

        <Video
          src={section.media.src}
          aria-label={section.media.alt}
          wrapperClass="w-full"
          class="aspect-2/1 w-full rounded-lg border border-base-300 bg-base-200 object-cover"
        />

        <div class="space-y-2 text-lg leading-6 text-base-content/90">
          <p>{section.intro}</p>
          <ul class="list-disc space-y-1 pl-6">
            {section.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </div>
      </section>
    ))
  }

  <!-- FINAL CTA -->
  <section class="mt-20 mb-20 flex flex-col items-center gap-8">
    <h2
      class="text-center text-pretty text-3xl font-bold tracking-tight sm:text-4xl"
    >
      Buy Now on Steam!
    </h2>

    <iframe
      src={STEAM_WIDGET_URL}
      title="Buy PS Maker on Steam"
      width="100%"
      height="190"
    >
    </iframe>
  </section>
</main>

<Footer />

<style>
  .ps-maker-hero {
    width: min(100vw, 80rem);
    margin-inline-start: calc(50% - min(50vw, 40rem));
  }
</style>
