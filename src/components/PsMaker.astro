---
import { Icon } from "@astrojs/starlight/components";
import Footer from "./Footer/Footer.astro";
import Video from "./Video.astro";
import homepageDemo1 from "../assets/images/home-page/homepage-demo-1.mp4";
import homepageDemo2 from "../assets/images/home-page/homepage-demo-2.mp4";
import homepageDemo3 from "../assets/images/home-page/homepage-demo-3.mp4";

const PLAY_DEMO_URL = "https://pixelstories.io/play/ae9fd4f0";
const STEAM_WIDGET_URL = "https://store.steampowered.com/widget/4823590/";
const STEAM_STORE_URL = "https://store.steampowered.com/app/4823590/PS_Maker/";

const featureSections = [
  {
    title: "Build Your World",
    media: {
      type: "video",
      src: homepageDemo1,
      alt: "PS Maker map editor showing a top-down pixel art world",
    },
    intro: "Use the 2D top-down map editor to build your world.",
    bullets: [
      "Map objects with top-down depth sorting",
      "Tilesets and autotiling support",
      "Map layers for tiles",
      "Overlay collisions",
      "Undo/Redo support",
    ],
  },
  {
    title: "Bring Your Story to Life",
    media: {
      type: "video",
      src: homepageDemo2,
      alt: "PS Maker no-code event system editing a game interaction",
    },
    intro:
      "Create your story, cutscenes, and set-up game logic without writing code.",
    bullets: [
      "No-code event system, driven by actions",
      "Control NPCs, trigger cutscenes, and build game mechanics",
      "Player interaction and touch trigger systems",
      "Built-in dialogue editor with names, portraits, and voice sounds",
      "Conditional branching with player choices and game variables",
      "Multiple endings",
    ],
  },
  {
    title: "Instantly Share with Friends",
    media: {
      type: "video",
      src: homepageDemo3,
      alt: "PS Maker playtest view running a top-down story game",
    },
    intro:
      "Once you're finished your project, instantly share it with your friends!",
    bullets: [],
  },
] as const;
---

<main
  class="not-content relative mx-auto flex max-w-10xl flex-col gap-32 px-0 sm:px-6 lg:px-8 max-sm:gap-20"
>
  <!-- HERO -->
  <section
    class="flex flex-col items-center gap-4 text-center not-content pt-10 pb-2"
  >
    <div
      class="flex w-full max-w-5xl flex-col items-center justify-between gap-5 md:flex-row md:gap-8"
    >
      <p
        class="flex max-w-4xl flex-wrap items-center justify-center gap-x-2 gap-y-1 text-pretty text-center text-4xl leading-8 font-semibold text-base-content md:justify-start md:text-left"
      >
        <span class="inline-flex gap-2 items-center">
          <img src="/logo-icon.png" alt="" class="size-11 border-0" />
          <span>PS Maker:</span>
        </span>
        <span> Story Game Engine </span>
      </p>

      <div
        class="flex w-full flex-col justify-center gap-3 sm:w-auto sm:flex-row sm:flex-wrap"
      >
        <a
          href="/overview"
          class="daisy-btn daisy-btn-outline border border-base-300"
        >
          Read the manual
        </a>
        <a
          href={PLAY_DEMO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="daisy-btn max-sm:hidden"
        >
          Open web demo
          <Icon name="right-arrow" size="1rem" />
        </a>
      </div>
    </div>

    <div class="relative w-full">
      <a
        href={PLAY_DEMO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="daisy-btn daisy-btn-sm absolute top-4 left-1/2 z-10 -translate-x-1/2 rounded-full border border-base-300 bg-base-100/95 shadow-sm backdrop-blur max-sm:hidden"
      >
        Open tutorial project
        <Icon name="right-arrow" size="0.875rem" />
      </a>

      <iframe
        src={PLAY_DEMO_URL}
        title="PS Maker tutorial game"
        class="w-full aspect-video rounded-lg border border-base-300 bg-base-200"
        allow="fullscreen; gamepad"
        loading="lazy"
      >
      </iframe>
    </div>
  </section>

  <section class="flex flex-col items-center gap-4 text-center sm:-mt-8">
    <p
      class="mx-auto w-full max-w-4xl text-balanced text-3xl font-medium leading-10 text-base-content max-sm:text-lg max-sm:leading-6"
    >
      Create 2D top-down story-driven exploration games without any coding. So
      you can focus on the narrative, characters, music and world building!
    </p>

    <a href={STEAM_STORE_URL} class="daisy-btn"> Buy now on Steam </a>
  </section>

  {
    featureSections.map((section) => (
      <section class="flex flex-col gap-4">
        <h2 class="text-pretty text-4xl font-bold tracking-tight max-sm:text-2xl">
          {section.title}
        </h2>

        <Video
          src={section.media.src}
          aria-label={section.media.alt}
          wrapperClass="w-full"
          class="aspect-2/1 w-full rounded-lg border border-base-300 bg-base-200 object-cover"
        />

        <div class="space-y-2 text-lg leading-6 text-base-content/90 max-sm:text-base">
          <p>{section.intro}</p>
          {section.bullets.length > 0 && (
            <ul class="list-disc space-y-1 pl-6">
              {section.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
        </div>
      </section>
    ))
  }

  <!-- FINAL CTA -->
  <section class="my-20 max-sm:my-0 flex flex-col items-center gap-8">
    <h2
      class="text-center text-pretty text-3xl font-bold tracking-tight sm:text-4xl"
    >
      Buy Now on Steam!
    </h2>

    <iframe
      src={STEAM_WIDGET_URL}
      title="Buy PS Maker on Steam"
      width="100%"
      height="190"
    >
    </iframe>
  </section>
</main>

<Footer />

<style>
  .ps-maker-hero {
    width: min(100vw, 80rem);
    margin-inline-start: calc(50% - min(50vw, 40rem));
  }
</style>
