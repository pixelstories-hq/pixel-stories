---
import { Icon } from "@astrojs/starlight/components";

const currentPath = Astro.url.pathname;

const showHamburger = currentPath === "/" || currentPath === "/community";
const showSteamButton = currentPath === "/";
const themeToggleLabel = Astro.locals.t("themeSelect.accessibleLabel");
const STEAM_STORE_URL = "https://store.steampowered.com/app/4823590/PS_Maker/";
const PRESS_KIT_URL = "https://impress.games/press-kit/pixel-stories/ps-maker";
---

<nav class="flex items-center gap-3">
  {
    showHamburger && (
      <button
        id="nav-toggle"
        class="inline-flex items-center justify-center rounded-full p-2 ring-1 ring-base-300/60 md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="bars" size="1.25rem" />
      </button>
    )
  }

  <!-- Desktop: Inline links -->
  <div class="hidden md:flex gap-2 w-max font-medium h-full">
    <a href="/blog" class="action sl-flex">News</a>
    <a href="/overview" class="action sl-flex">PS Maker Manual</a>
    <a
      href={PRESS_KIT_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="action sl-flex"
    >
      Press kit <Icon name="external" size="1rem" />
    </a>
    <a
      href="https://discord.gg/WTxUC4hEnS"
      target="_blank"
      rel="noopener noreferrer"
      class="action sl-flex"
    >
      Discord <Icon name="external" size="1rem" />
    </a>
  </div>

  <!-- Desktop: Theme selector -->
  <div class="hidden md:block">
    <label
      class="daisy-toggle daisy-toggle-md text-base-content/70 theme-toggle mb-0.5 -mx-1"
    >
      <input type="checkbox" aria-label={themeToggleLabel} data-theme-toggle />
      <Icon name="sun" size="16px" aria-label="light mode" />
      <Icon name="moon" size="16px" aria-label="dark mode" />
    </label>
  </div>

  {
    showSteamButton && (
      <div class="hidden md:block">
        <a
          href={STEAM_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="daisy-btn daisy-btn-primary daisy-btn-sm ml-2.5"
        >
          Buy now on Steam
        </a>
      </div>
    )
  }
</nav>

<div
  id="backdrop"
  class="fixed inset-0 z-40 hidden h-dvh w-dvh bg-base-300/60 backdrop-blur-[1px] data-[open=true]:block"
>
</div>

<div
  id="mobile-menu"
  class="fixed left-3 right-3 top-14 z-50 hidden rounded-2xl border border-base-300 bg-base-100 p-3 text-base-content shadow-xl data-[open=true]:block md:hidden"
  role="dialog"
  aria-modal="true"
>
  <div class="flex flex-col gap-1.5 font-medium">
    <a href="/blog" class="mobile-link">News</a>

    <a href="/overview" class="mobile-link">PS Maker Manual</a>
    <a
      href={PRESS_KIT_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-link"
      >Press kit <Icon name="external" size="0.9rem" class="opacity-65" /></a
    >
    <a
      href="https://discord.gg/WTxUC4hEnS"
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-link"
      >Discord <Icon name="external" size="0.9rem" class="opacity-65" /></a
    >
  </div>

  <div class="mt-3 flex items-center justify-between gap-2">
    <a
      href={STEAM_STORE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="daisy-btn daisy-btn-primary daisy-btn-sm w-max justify-center"
      >Buy now on Steam
    </a>

    <!-- Mobile Theme select -->
    <div class="shrink-0">
      <label
        class="daisy-toggle daisy-toggle-md text-base-content/70 theme-toggle"
      >
        <input
          type="checkbox"
          aria-label={themeToggleLabel}
          data-theme-toggle
        />
        <Icon name="sun" aria-label="light mode" />
        <Icon name="moon" aria-label="dark mode" />
      </label>
    </div>
  </div>
</div>

<style>
  .action {
    gap: 0.25em;
    align-items: center;
    border-radius: 999rem;
    padding: 0.25rem 0.75rem;
    color: var(--color-base-content);
    line-height: 1.1875;
    text-decoration: none;
    font-size: var(--sl-text-sm);
    transition: opacity 250ms;
  }
  .action:hover {
    opacity: 0.6;
  }

  .divider {
    border-inline-end: 1px solid var(--color-base-300);
    padding-inline-end: 1rem;
  }

  .mobile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.75rem;
    color: var(--color-base-content);
    text-decoration: none;
  }
  .mobile-link:hover {
    background: color-mix(in oklab, var(--color-base-content) 8%, transparent);
  }

  .theme-toggle {
    vertical-align: middle;
  }
</style>

<script>
  type Theme = "auto" | "dark" | "light";

  const storageKey = "starlight-theme";
  const initializedThemeToggles = new WeakSet<HTMLInputElement>();
  const initializedMenuControls = new WeakSet<Element>();

  const parseTheme = (theme: unknown): Theme =>
    theme === "auto" || theme === "dark" || theme === "light" ? theme : "auto";

  const loadTheme = (): Theme =>
    parseTheme(
      typeof localStorage !== "undefined" && localStorage.getItem(storageKey),
    );

  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== "undefined") {
      localStorage.setItem(
        storageKey,
        theme === "light" || theme === "dark" ? theme : "",
      );
    }
  }

  const getPreferredColorScheme = (): Theme =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  function syncThemeToggles(root: ParentNode, resolvedTheme: Theme): void {
    root
      .querySelectorAll<HTMLInputElement>("[data-theme-toggle]")
      .forEach((toggle) => {
        toggle.checked = resolvedTheme === "dark";
      });
  }

  function applyTheme(theme: Theme): void {
    const resolvedTheme = theme === "auto" ? getPreferredColorScheme() : theme;
    document.documentElement.dataset.theme = resolvedTheme;
    syncThemeToggles(document, resolvedTheme);
  }

  function initializeThemeToggles(): void {
    applyTheme(loadTheme());
    document
      .querySelectorAll<HTMLInputElement>("[data-theme-toggle]")
      .forEach((toggle) => {
        if (initializedThemeToggles.has(toggle)) return;
        initializedThemeToggles.add(toggle);
        toggle.addEventListener("change", () => {
          const nextTheme: Theme = toggle.checked ? "dark" : "light";
          applyTheme(nextTheme);
          storeTheme(nextTheme);
        });
      });
  }

  function getMenuElements() {
    const btn = document.getElementById("nav-toggle");
    const closeBtn = document.getElementById("nav-close");
    const menu = document.getElementById("mobile-menu");
    const backdrop = document.getElementById("backdrop");

    return { btn, closeBtn, menu, backdrop };
  }

  function closeMenu({ focusButton = true } = {}): void {
    const { btn, menu, backdrop } = getMenuElements();
    if (!menu || !backdrop || !btn) return;

    delete menu.dataset.open;
    delete backdrop.dataset.open;
    btn.setAttribute("aria-expanded", "false");
    if (focusButton) btn.focus();
  }

  function openMenu(): void {
    const { btn, menu, backdrop } = getMenuElements();
    if (!menu || !backdrop || !btn) return;

    menu.dataset.open = "true";
    backdrop.dataset.open = "true";
    btn.setAttribute("aria-expanded", "true");
    menu.querySelector("a")?.focus();
  }

  function initializeMobileMenu(): void {
    const { btn, closeBtn, menu, backdrop } = getMenuElements();

    if (btn && !initializedMenuControls.has(btn)) {
      initializedMenuControls.add(btn);
      btn.addEventListener("click", () => {
        if (!menu) return;
        menu.dataset.open === "true" ? closeMenu() : openMenu();
      });
    }

    if (closeBtn && !initializedMenuControls.has(closeBtn)) {
      initializedMenuControls.add(closeBtn);
      closeBtn.addEventListener("click", () => closeMenu());
    }

    if (backdrop && !initializedMenuControls.has(backdrop)) {
      initializedMenuControls.add(backdrop);
      backdrop.addEventListener("click", () => closeMenu());
    }
  }

  function initializeHeaderControls(): void {
    initializeThemeToggles();
    initializeMobileMenu();
  }

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (loadTheme() === "auto") applyTheme("auto");
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  document.addEventListener(
    "astro:before-swap",
    (event: Event & { newDocument: Document }) => {
      const resolvedTheme = document.documentElement.dataset.theme as
        | Theme
        | undefined;

      if (!resolvedTheme) return;

      event.newDocument.documentElement.dataset.theme = resolvedTheme;
      syncThemeToggles(event.newDocument, resolvedTheme);
    },
  );

  document.addEventListener("astro:page-load", initializeHeaderControls);
  initializeHeaderControls();
</script>
