---
import { Image } from "astro:assets";
import PlaceholderCover from "../../assets/images/placeholder-cover.png";

interface Props {
  cover?: {
    alt: string;
    // from astro image src prop
    image: {
      src: string;
      width: number;
      height: number;
      format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
    };
  };
  title: string;
  date?: Date;
  excerpt?: string;
  tags?: string[];
  url: string;

  largeCover?: boolean;
}

const { cover, title, date, tags, excerpt, url, largeCover } = Astro.props;
---

<div
  class="not-content h-full w-full max-w-xl rounded-lg border border-base-300 bg-base-100 text-base-content shadow-lg"
>
  <a href={url}>
    <Image
      class="not-content rounded-t-lg max-w-full w-full h-[200px] object-cover"
      class:list={[{ "h-[350px]": largeCover }]}
      src={cover?.image || PlaceholderCover}
      alt={cover?.alt || "Placeholder cover"}
    />
  </a>

  <div class="p-5">
    <a href={url}>
      <h5 class="mb-2 text-2xl font-bold text-base-content hover:opacity-70">
        {title}
      </h5>
    </a>

    {
      date && (
        <time class="font-mono text-sm mb-1">
          {date.toLocaleDateString("en-us", {
            year: "numeric",
            month: "short",
            day: "numeric",
          })}
        </time>
      )
    }

    {excerpt && <p class="font-normal mb-3 line-clamp-4">{excerpt}</p>}

    <div class="flex gap-2 flex-wrap">
      {
        tags?.map((tag) => (
          <p class="w-max rounded-lg border border-base-300 p-1 px-2 text-xs text-base-content/80">
            {tag}
          </p>
        ))
      }
    </div>
  </div>
</div>

<style>
  a {
    text-decoration: none;
  }
</style>
