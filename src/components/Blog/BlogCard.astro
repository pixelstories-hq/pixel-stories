---
import { Image } from "astro:assets";
import PlaceholderCover from "../../assets/images/placeholder-cover.png";

interface Props {
  cover?: {
    alt: string;
    // from astro image src prop
    image: {
      src: string;
      width: number;
      height: number;
      format: "png" | "jpg" | "jpeg" | "tiff" | "webp" | "gif" | "svg" | "avif";
    };
  };
  title: string;
  date?: Date;
  excerpt?: string;
  tags?: string[];
  url: string;
}

const { cover, title, date, tags, excerpt, url } = Astro.props;
---

<div
  class="not-content h-full w-full max-w-xl bg-base-100 text-base-content flex flex-col"
>
  <a href={url}>
    <Image
      class="not-content rounded-lg border border-base-300 !h-[200px] max-w-full w-full object-cover aspect-video hover:brightness-110 transition-all"
      src={cover?.image || PlaceholderCover}
      alt={cover?.alt || "Placeholder cover"}
    />
  </a>

  <div class="p-1 flex flex-col gap-4 grow">
    <div class="grow flex flex-col gap-3">
      <div class="flex justify-between items-center">
        {
          date && (
            <time class=" text-xs">
              {date.toLocaleDateString("en-us", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
          )
        }

        <div class="flex gap-2 flex-wrap">
          {
            tags?.map((tag) => (
              <p class="daisy-badge daisy-badge-ghost daisy-badge-sm">{tag}</p>
            ))
          }
        </div>
      </div>

      <a href={url}>
        <h5
          class="text-xl font-semibold text-base-content hover:opacity-60 transition-all"
        >
          {title}
        </h5>
      </a>

      {excerpt && <p class="font-normal text-sm line-clamp-3">{excerpt}</p>}
    </div>
  </div>
</div>

<style>
  a {
    text-decoration: none;
  }
</style>
